# Resend API key for the /api/contact route.
# Sign up at https://resend.com, verify the crafterexplorer.co.uk domain,
# create an API key, and paste it here (and in Vercel env vars for production).
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=info@crafterexplorer.co.uk

# The verified "from" address on your Resend domain (must be on a verified domain).
CONTACT_FROM_EMAIL=website@crafterexplorer.co.uk
